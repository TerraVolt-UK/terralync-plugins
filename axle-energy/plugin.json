{
  "id": "axle-energy",
  "name": "Axle Energy VPP",
  "version": "1.0.0",
  "min_terralync": "1.0.0",
  "author": "TerraLync Team",
  "description": "Virtual Power Plant integration for Axle Energy. Automatically responds to grid events by exporting battery power at full capacity during scheduled events.",
  "license": "MIT",
  "homepage": "https://github.com/TerraVolt-UK/terralync-plugins",
  "entry_point": "main.py",

  "permissions": {
    "read_inverter_data": true,
    "read_historian": false,
    "write_inverter": true,
    "write_scheduler": false,
    "network_access": true,
    "filesystem": "own_dir"
  },

  "lifecycle": {
    "start_delay_seconds": 5,
    "restart_on_crash": true,
    "max_restarts": 3,
    "restart_cooldown_seconds": 60,
    "health_check_interval_seconds": 60
  }
}
