{
  "id": "engineering-mode",
  "name": "Engineering Mode",
  "version": "1.0.0",
  "min_terralync": "1.0.0",
  "author": "TerraLync Team",
  "description": "Enables engineering-level inverter configuration commands. WARNING: Incorrect use can void warranty, damage equipment, or violate grid regulations.",
  "license": "Proprietary",
  "entry_point": "main.py",

  "permissions": {
    "read_inverter_data": true,
    "write_inverter": true,
    "read_historian": false,
    "write_scheduler": false,
    "network_access": false,
    "filesystem": "own_dir"
  },

  "lifecycle": {
    "start_delay_seconds": 2,
    "restart_on_crash": true,
    "max_restarts": 3,
    "restart_cooldown_seconds": 30,
    "health_check_interval_seconds": 60
  }
}
